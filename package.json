{
  "name": "zhihu-sidebar",
  "displayName": "Zhihu Sidebar",
  "description": "在 VSCode 底部面板中查看知乎推荐内容。",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:zhihuSidebar.view",
    "onCommand:zhihuSidebar.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zhihuSidebar.refresh",
        "title": "刷新知乎内容"
      },
      {
        "command": "zhihuSidebar.openSettings",
        "title": "打开知乎插件设置"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "zhihuSidebar",
          "title": "Zhihu",
          "icon": "media/zhihu.svg"
        }
      ]
    },
    "views": {
      "zhihuSidebar": [
        {
          "id": "zhihuSidebar.view",
          "name": "知乎推荐",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Zhihu Sidebar",
      "properties": {
        "zhihuSidebar.cookie": {
          "type": "string",
          "default": "",
          "markdownDescription": "知乎请求使用的 Cookie。请在已登录知乎的浏览器开发者工具里复制完整的 `Cookie` 请求头内容粘贴到这里。",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  }
}
